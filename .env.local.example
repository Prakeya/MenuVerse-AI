# AWS DynamoDB Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# OpenAI API Key (optional - for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# DynamoDB Table Names (optional - defaults shown)
# DYNAMODB_MENU_ITEMS_TABLE=MenuItems
# DYNAMODB_ORDERS_TABLE=Orders
# DYNAMODB_ANALYTICS_TABLE=Analytics
# DYNAMODB_TABLES_TABLE=Tables
# DYNAMODB_LOYALTY_TABLE=Loyalty
# DYNAMODB_RATINGS_TABLE=Ratings